PORT=3000

# Credenciales del administrador
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contrasena

# Clave secreta de sesión (cambia esto por algo aleatorio)
SESSION_SECRET=clave_secreta_muy_larga_y_aleatoria

# Base de datos Turso (SQLite en la nube)
# Crea una cuenta gratis en https://turso.tech
# luego ejecuta: turso db create mi-cambio-aceite
# y: turso db tokens create mi-cambio-aceite
TURSO_DATABASE_URL=libsql://tu-base-de-datos.turso.io
TURSO_AUTH_TOKEN=tu_token_de_turso

# Correo (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=onboarding@resend.dev

PORT=3000

# Credenciales del administrador
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contrasena

# Clave secreta de sesión (cambia esto por algo aleatorio)
SESSION_SECRET=clave_secreta_muy_larga_y_aleatoria

# Correo para enviar confirmaciones (Gmail)
# Para Gmail necesitas un "App Password" (contraseña de aplicación):
# 1. Ve a myaccount.google.com → Seguridad → Verificación en 2 pasos
# 2. Al final de esa página busca "Contraseñas de aplicaciones"
# 3. Crea una para "Correo" y copia los 16 caracteres aquí
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
